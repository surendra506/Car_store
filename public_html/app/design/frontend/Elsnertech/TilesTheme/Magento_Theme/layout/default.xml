<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Custom header -->
        <referenceContainer name="header.container">
            <block class="Magento\Framework\View\Element\Template"
                   name="lambo.header"
                   as="lambo_header"
                   template="Magento_Theme::html/lambo_header.phtml"
                   before="-">
                <block class="Magento\Theme\Block\Html\Topmenu"
                       name="lambo.catalog.topnav"
                       as="catalog.topnav"
                       template="Magento_Theme::html/topmenu.phtml"
                       ttl="3600"/>
            </block>
        </referenceContainer>

        <!-- Hide default Magento nav sections (we render topmenu inside lambo header) -->
        <referenceBlock name="navigation.sections" remove="true"/>

        <!-- Custom footer -->
        <referenceContainer name="footer-container">
            <referenceBlock name="footer_links" remove="true"/>
            <referenceBlock name="copyright" remove="true"/>
            <block class="Magento\Framework\View\Element\Template"
                   name="lambo.custom.footer"
                   as="lambo_custom_footer"
                   template="Magento_Theme::html/custom-footer.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>

